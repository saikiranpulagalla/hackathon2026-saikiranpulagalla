# Get your GROQ_API_KEY from https://console.groq.com/keys
# Sign up, create an API key, and paste it here
GROQ_API_KEY=your_groq_api_key_here

# LangSmith Tracing (optional — get a key at https://smith.langchain.com)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=shopwave-hackathon-2026
LANGCHAIN_TRACING_V2=true

# DEMO ONLY: Override confidence score to test specific routing behavior
# Set to 0.72 to demonstrate secondary gate (refund >$100 with moderate confidence)
# Leave as 0 (disabled) for normal operation
DEMO_CONFIDENCE_OVERRIDE=0
